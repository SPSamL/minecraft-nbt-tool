<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>minecraft_nbt_tool</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RuntimeIdentifiers>win-x64;linux-x64;linux-arm64;osx-x64;osx-arm64</RuntimeIdentifiers>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SharpNBT" Version="1.3.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="BlueprintScanner.cs" />
    <Compile Remove="BlueprintWebServer.cs" />
    <Compile Remove="CommandLine.cs" />
    <Compile Remove="CsvExporter.cs" />
    <Compile Remove="Models.cs" />
    <Compile Remove="ScanInputResolver.cs" />
  </ItemGroup>

</Project>
